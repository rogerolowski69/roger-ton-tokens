DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/roger_tokens

BOT_TOKEN=123456:ABC...
TELEGRAM_WEBHOOK_SECRET=long_random_secret_here

API_BASE_URL=http://localhost:3001
MINI_APP_URL=http://localhost:5173

MERCHANT_TON_WALLET=
# On-chain TIME jetton minter (optional). Set after `just deploy-testnet`;
