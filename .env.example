ALLOWED_ORIGINS=

RUN_MIGRATIONS_ON_STARTUP=true
SEED_PRODUCTS_ON_STARTUP=true

APP_DEBUG=true
LOG_LEVEL=DEBUG
LOG_JSON=false
SQL_ECHO=false

# Acton / TON Center (optional for testnet scripts)
TONCENTER_API_KEY=
