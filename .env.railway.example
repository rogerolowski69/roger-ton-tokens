# Copy these into Railway service variables (API service unless noted)

# --- Required (API) ---
DATABASE_URL=${{Postgres.DATABASE_URL}}
BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
API_BASE_URL=https://your-api.up.railway.app
MINI_APP_URL=https://your-frontend.up.railway.app

# --- Recommended (API) ---
MERCHANT_TON_WALLET=
JETTON_MASTER_ADDRESS=
ALLOWED_ORIGINS=
RUN_MIGRATIONS_ON_STARTUP=true
SEED_PRODUCTS_ON_STARTUP=true
APP_DEBUG=false
LOG_LEVEL=INFO
LOG_JSON=true

# --- Frontend service only (build-time) ---
# VITE_API_BASE_URL=https://your-api.up.railway.app
# VITE_MINI_APP_URL=https://your-frontend.up.railway.app

# --- Optional TON scripts (local / worker) ---
# TONCENTER_API_KEY=
