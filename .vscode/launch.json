{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API (uvicorn + debugpy)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["apps.api.main:app", "--reload", "--port", "3001"],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": false
    },
    {
      "name": "API (attach debugpy :5678)",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5678
      },
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}",
          "remoteRoot": "."
        }
      ],
      "justMyCode": false
    }
  ]
}
